n>\n  </view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">信令连接</view>\n  <view class=\"actions signal-actions\">\n    <input class=\"signal-input\" placeholder=\"wss://...\" value=\"{{signalUrl}}\" bindinput=\"onSignalUrlInput\" />\n    <button bindtap=\"connectSignal\">连接</button>\n    <button bindtap=\"disconnectSignal\">断开</button>\n  </view>\n  <view class=\"actions\">\n    <button bindtap=\"sendQuickHeartbeat\">发心跳</button>\n    <button bindtap=\"sendQuickSync\">发同步</button>\n    <button bindtap=\"sendQuickAck\">发 ACK</button>\n    <button bindtap=\"sendQuickDrawOffer\">提和</button>\n    <button bindtap=\"sendQuickDrawResponse\">同意平局</button>\n    <button bindtap=\"sendQuickResign\">认输</button>\n    <button bindtap=\"sendQuickError\">发异常</button>\n  </view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">在线匹配模拟面板</view>\n  <view class=\"actions\">\n    <button bindtap=\"resetMatchRoom\">重置房间</button>\n    <button bindtap=\"simulateOnlineRequest\">发起匹配</button>\n    <button bindtap=\"simulateOnlineAccept\">接受匹配</button>\n    <button bindtap=\"simulateOnlineSync\">同步局面</button>\n    <button bindtap=\"simulateOnlineHeartbeat\">心跳</button>\n    <button bindtap=\"simulateOnlineDrawOffer\">提和</button>\n    <button bindtap=\"simulateOnlineDrawAccept\">同意平局</button>\n    <button bindtap=\"simulateOnlineResign\">认输</button>\n    <button bindtap=\"simulateOnlineError\">模拟异常</button>\n  </view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">信令日志</view>\n  <view wx:for=\"{{logLines}}\" wx:key=\"*this\" class=\"log-line\">{{item}}</view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">提示说明</view>\n  <view wx:for=\"{{tips}}\" wx:key=\"*this\">- {{item}}</view>\n</view>\n","file_path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.wxml","path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.wxml"}}],"api":"openai-comp