{"type":"message","id":"7a465876","parentId":"c6ddcc87","timestamp":"2026-03-21T13:53:45.824Z","message":{"role":"toolResult","toolCallId":"call_VYydmfsoQIL0oWCG3jIGuz4b","toolName":"read","content":[{"type":"text","text":"<view class=\"card\">\n  <view class=\"section-title\">{{state.message}}</view>\n  <view class=\"meta\">模式：{{state.mode}} · 当前：{{state.side}} · 步数：{{state.moveCount}}</view>\n  <view class=\"hint-box\">{{hintText}}</view>\n\n  <view class=\"status-box\">\n    <view class=\"status-line\">{{connectionStatus}}</view>\n    <view class=\"status-line\">协议状态：{{matchRoom.state}} · 回合：{{matchRoom.turn}} · 序号：{{matchRoom.sequence}}</view>\n  </view>\n\n  <view class=\"board-shell\">\n    <view class=\"board-grid\">\n      <block wx:for=\"{{boardRows}}\" wx:for-item=\"row\" wx:key=\"y\">\n        <view class=\"board-row\">\n          <block wx:for=\"{{row.cells}}\" wx:for-item=\"cell\" wx:key=\"key\">\n            <view\n              class=\"board-cell {{cell.selected ? 'cell-selected' : ''}} {{cell.legalTarget ? 'cell-legal' : ''}} {{cell.hintTarget ? 'cell-hint' : ''}} {{cell.syncTarget ? 'cell-sync' : ''}} {{cell.lastMove ? 'cell-lastmove' : ''}}\"\n              data-x=\"{{cell.x}}\"\n              data-y=\"{{cell.y}}\"\n              bindtap=\"onCellTap\"\n            >\n              <view wx:if=\"{{cell.legalTarget && !cell.piece}}\" class=\"legal-dot\"></view>\n              <view wx:if=\"{{cell.piece}}\" class=\"piece piece-{{cell.piece.side}} {{cell.selected ? 'piece-selected' : ''}}\">\n                {{cell.text}}\n              </view>\n            </view>\n          </block>\n        </view>\n      </block>\n    </view>\n  </view>\n\n  <view class=\"actions\">\n    <button class=\"button-primary\" bindtap=\"startGame\">重新开始</button>\n    <button bindtap=\"undoMove\">悔棋</button>\n    <button bindtap=\"showHint\">提示</button>\n    <button bindtap=\"goResult\">去结算页</button>\n  </view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">在线匹配模拟面板</view>\n  <view class=\"actions\">\n    <button bindtap=\"resetMatchRoom\">重置房间</button>\n    <button bindtap=\"simulateOnlineRequest\">发起匹配</button>\n    <button bindtap=\"simulateOnlineAccept\">接受匹配</button>\n    <button bindtap=\"simulateOnlineSync\">同步局面</button>\n    <button bindtap=\"simulateOnlineHeartbeat\">心跳</button>\n    <button bindtap=\"simulateOnlineDrawOffer\">提和</button>\n    <button bindtap=\"simulateOnlineDrawAccept\">同意平局</button>\n    <button bindtap=\"simulateOnlineResign\">认输</button>\n    <button bindtap=\"simulateOnlineError\">模拟异常</button>\n  </view>\n</view>\n\n<view class=\"card\">\n  <view class=\"section-title\">提示说明</view>\n  <view wx:for=\"{{tips}}\" wx:key=\"*this\">- {{item}}</view>\n</view>\n"}],"isError":false,"timestamp":1774101225816}}
{"type":"message","id":"dd3ebfe3","parentId":"7a465876","timestamp":"2026-03-21T13:53:45.835Z","message":{"role":"toolResult","toolCallId":"call_rjpPi1LrlMDUmximsw05vjDA","toolName":"read","content":[{"type":"text","text":".section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; }\n.meta { color: #666; margin-bottom: 12rpx; }\n.hint-box {\n  margin-bottom: 18rpx;\n  padding: 14rpx 16rpx;\n  border-radius: 16rpx;\n  background: rgba(255, 255, 255, 0.65);\n  color: #8a5a14;\n  font-size: 26rpx;\n}\n.status-box {\n  margin-bottom: 18rpx;\n  padding: 14rpx 16rpx;\n  border-radius: 16rpx;\n  background: rgba(255, 255, 255, 0.72);\n}\n.status-line {\n  color: #555;\n  font-size: 24rpx;\n  line-height: 1.6;\n}\n.board-shell {\n  padding: 18rpx;\n  background: #ead9b4;\n  border-radius: 24rpx;\n  margin-bottom: 20rpx;\n}\n.board-grid {\n  background: #f8e8c4;\n  border: 2rpx solid #a07b46;\n  border-radius: 16rpx;\n  overflow: hidden;\n}\n.board-row {\n  display: flex;\n}\n.board-cell {\n  width: 76rpx;\n  height: 76rpx;\n  box-sizing: border-box;\n  border-right: 1rpx solid rgba(160, 123, 70, 0.35);\n  border-bottom: 1rpx solid rgba(160, 123, 70, 0.35);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  position: relative;\n}\n.board-row:last-child .board-cell { border-bottom: none; }\n.board-cell:last-child { border-right: none; }\n.cell-selected { background: rgba(184, 54, 45, 0.18); }\n.cell-legal { background: rgba(43, 122, 77, 0.12); }\n.cell-hint { background: rgba(76, 95, 255, 0.16); }\n.cell-sync { background: rgba(145, 83, 255, 0.16); }\n.cell-lastmove { background: rgba(255, 214, 102, 0.18); }\n.legal-dot {\n  width: 18rpx;\n  height: 18rpx;\n  border-radius: 50%;\n  background: rgba(43, 122, 77, 0.7);\n}\n.piece {\n  width: 58rpx;\n  height: 58rpx;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 30rpx;\n  font-weight: 700;\n  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);\n}\n.piece-red {\n  background: #f8efe2;\n  color: #b8362d;\n  border: 2rpx solid #c06b63;\n}\n.piece-black {\n  background: #f6f1e8;\n  color: #333;\n  border: 2rpx solid #666;\n}\n.piece-selected { transform: scale(1.04); }\n.actions { display: flex; gap: 16rpx; flex-wrap: wrap; }\nbutton { margin-top: 16rpx; }\n"}],"isError":false,"timestamp":1774101225827}}
{"type":"message","id":"ce391609","parentId":"dd3ebfe3","timestamp":"2026-03-21T13:53:45.845Z","message":{"role":"toolResult","toolCallId":"call_X7b2zRhpcxdlNYcqXF3pKgsm","toolName":"read","content":[{"type":"text","text":"const {\n  MatchEventType,\n  createAckEvent,\n  createDrawOfferEvent,\n  createDrawResponseEvent,\n  createErrorEvent,\n  createHeartbeatEvent,\n  createMatchRoom,\n  createMoveEvent,\n  createResignEvent,\n  createSyncEvent,\n  isProtocolEnvelope,\n  applyMatchEvent,\n} = require('./match-protocol');\n\nconst TransportStatus = Object.freeze({\n  IDLE: 'idle',\n  CONNECTING: 'connecting',\n  OPEN: 'open',\n  CLOSING: 'closing',\n  CLOSED: 'closed',\n  ERROR: 'error',\n});\n\nfunction safeJsonParse(raw) {\n  if (raw && typeof raw === 'object') return raw;\n  if (typeof raw !== 'string') return null;\n  try {\n    return JSON.parse(raw);\n  } catch (error) {\n    return null;\n  }\n}\n\nfunction buildWxSocketAdapter(wxApi = typeof wx !== 'undefined' ? wx : null) {\n  if (!wxApi || typeof wxApi.connectSocket !== 'function') {\n    throw new Error('wx socket API is unavailable');\n  }\n\n  return {\n    open(url, handlers = {}) {\n      const task = wxApi.connectSocket({ url });\n      const bind = (method, handler) => {\n        if (task && typeof task[method] === 'function') task[method](handler);\n      };\n\n      bind('onOpen', (event) => handlers.onOpen && handlers.onOpen(event));\n      bind('onClose', (event) => handlers.onClose && handlers.onClose(event));\n      bind('onError', (event) => handlers.onError && handlers.onError(event));\n      bind('onMessage', (event) => handlers.onMessage && handlers.onMessage(event.data));\n\n      return {\n        send(data) {\n          wxApi.sendSocketMessage({\n            data,\n            success: (res) => handlers.onSendSuccess && handlers.onSendSuccess(res),\n            fail: (err) => handlers.onSendError && handlers.onSendError(err),\n          });\n        },\n        close(code = 1000, reason = 'client close') {\n          if (typeof wxApi.closeSocket === 'function') {\n            wxApi.closeSocket({ code, reason });\n          }\n        },\n      };\n    },\n  };\n}\n\nfunction createMatchSignalClient({\n  room = createMatchRoom(),\n  url = '',\n  adapter = null,\n  onRoomChange = null,\n  onTransportChange = null,\n  onEnvelope = null,\n  onError = null,\n} = {}) {\n  const listeners = {\n    roomChange: onRoomChange,\n    transportChange: onTransportChange,\n    envelope: onEnvelope,\n    error: onError,\n  };\n\n  let transport = null;\n  let transportState = {\n    status: TransportStatus.IDLE,\n    url,\n    lastError: null,\n    connectedAt: null,\n    closedAt: null,\n    lastMessageAt: null,\n  };\n  let roomState = room;\n\n  const socketAdapter = adapter || (typeof wx !== 'undefined' ? buildWxSocketAdapter(wx) : null);\n\n  function emit(kind, payload, extra) {\n    const handler = listeners[kind];\n    if (typeof handler === 'function') handler(payload, extra);\n  }\n\n  function setTransportState(patch) {\n    transportState = { ...transportState, ...patch };\n    emit('transportChange', transportState, clientApi);\n  }\n\n  function setRoomState(nextRoom, envelope = null) {\n    roomState = nextRoom;\n    emit('roomChange', roomState, envelope, clientApi);\n  }\n\n  function handleEnvelope(envelope) {\n    if (!isProtocolEnvelope(envelope)) {\n      const error = { code: 'INVALID_ENVELOPE', message: 'not a valid protocol envelope', raw: envelope };\n      setTransportState({ status: TransportStatus.ERROR, lastError: error });\n      emit('error', error, clientApi);\n      return;\n    }\n\n    const nextRoom = applyMatchEvent(roomState, envelope);\n    setRoomState(nextRoom, envelope);\n    setTransportState({ lastMessageAt: envelope.ts || Date.now(), lastError: null });\n    emit('envelope', envelope, clientApi);\n  }\n\n  const clientApi = {\n    getTransportState: () => transportState,\n    getRoom: () => roomState,\n    setHandlers(nextHandlers = {}) {\n      Object.assign(listeners, nextHandlers);\n      return clientApi;\n    },\n    connect(nextUrl = transportState.url) {\n      if (!socketAdapter) {\n        const error = { code: 'ADAPTER_MISSING', message: 'socket adapter is unavailable' };\n        setTransportState({ status: TransportStatus.ERROR, lastError: error });\n        emit('error', error, clientApi);\n        return false;\n      }\n      if (!nextUrl) {\n        const error = { code: 'EMPTY_URL', message: 'signaling url is empty' };\n        setTransportState({ status: TransportStatus.ERROR, lastError: error });\n        emit('error', error, clientApi);\n        return false;\n      }\n\n      if (transport) {\n        clientApi.disconnect();\n      }\n\n      setTransportState({ status: TransportStatus.CONNECTING, url: nextUrl, lastError: null });\n      transport = socketAdapter.open(nextUrl, {\n        onOpen() {\n          setTransportState({ status: TransportStatus.OPEN, connectedAt: Date.now(), lastError: null });\n        },\n        onMessage(raw) {\n          const parsed = safeJsonParse(raw);\n          if (!parsed) {\n            const error = { code: 'PARSE_ERROR', message: 'message is not valid JSON', raw };\n            setTransportState({ status: TransportStatus.ERROR, lastError: error });\n            emit('error', error, clientApi);\n            return;\n          }\n          handleEnvelope(parsed);\n        },\n        onClose(event) {\n          setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now(), lastError: null, closeEvent: event || null });\n          transport = null;\n        },\n        onError(event) {\n          const error = { code: 'SOCKET_ERROR', message: 'socket error', event: event || null };\n          setTransportState({ status: TransportStatus.ERROR, lastError: error });\n          emit('error', error, clientApi);\n        },\n        onSendError(err) {\n          const error = { code: 'SEND_ERROR', message: 'failed to send socket message', event: err || null };\n          setTransportState({ status: TransportStatus.ERROR, lastError: error });\n          emit('error', error, clientApi);\n        },\n      });\n\n      return true;\n    },\n    disconnect() {\n      if (!transport) {\n        setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now() });\n        return true;\n      }\n      setTransportState({ status: TransportStatus.CLOSING });\n      try {\n        transport.close();\n      } finally {\n        transport = null;\n        setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now() });\n      }\n      return true;\n    },\n    sendEnvelope(envelope) {\n      if (!transport || transportState.status !== TransportStatus.OPEN) return false;\n      transport.send(JSON.stringify(envelope));\n      return true;\n    },\n    sendMove(move, meta = {}) {\n      return clientApi.sendEnvelope(createMoveEvent({ roomId: roomState.roomId, senderId: roomState.selfId, move, seq: meta.seq || roomState.sequence }));\n    },\n    sendAck(ackSeq, hash = null) {\n      return clientApi.sendEnvelope(createAckEvent({ roomId: roomState.roomId, senderId: roomState.selfId, ackSeq, hash }));\n    },\n    sendSync(board, turn, moveSeq = 0) {\n      return clientApi.sendEnvelope(createSyncEvent({ roomId: roomState.roomId, senderId: roomState.selfId, board, turn, moveSeq }));\n    },\n    sendHeartbeat(ping = Date.now()) {\n      return clientApi.sendEnvelope(createHeartbeatEvent({ roomId: roomState.roomId, senderId: roomState.selfId, ping }));\n    },\n    sendDrawOffer() {\n      return clientApi.sendEnvelope(createDrawOfferEvent({ roomId: roomState.roomId, senderId: roomState.selfId }));\n    },\n    sendDrawResponse(accepted = false) {\n      return clientApi.sendEnvelope(createDrawResponseEvent({ roomId: roomState.roomId, senderId: roomState.selfId, accepted }));\n    },\n    sendResign() {\n      return clientApi.sendEnvelope(createResignEvent({ roomId: roomState.roomId, senderId: roomState.selfId }));\n    },\n    sendError(code, message) {\n      return clientApi.sendEnvelope(createErrorEvent({ roomId: roomState.roomId, senderId: roomState.selfId, code, message }));\n    },\n    ingest(raw) {\n      const parsed = safeJsonParse(raw);\n      if (!parsed) return false;\n      handleEnvelope(parsed);\n      return true;\n    },\n    applyIncomingEnvelope(envelope) {\n      handleEnvelope(envelope);\n      return roomState;\n    },\n    dispose() {\n      clientApi.disconnect();\n    },\n  };\n\n  return clientApi;\n}\n\nmodule.exports = {\n  TransportStatus,\n  safeJsonParse,\n  buildWxSocketAdapter,\n  createMatchSignalClient,\n};\n"}],"isError":false,"timestamp":1774101225837}}
{"type":"message","id":"5eb9d253","parentId":"ce391609","timestamp":"2026-03-21T13:53:54.884Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_49HJr13Sh0GQFgkNF0AgriTC","name":"read","arguments":{"file_path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.js","limit":120,"offset":220,"path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.js"}}],"api":"openai-completions","provider":"code889","model":"gpt-5.4-mini","usage":{"input":3833,"output":846,"cacheRead":89088,"cacheWrite":0,"totalTokens":93767,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774101225844}}
{"type":"message","id":"65b2a263","parentId":"5eb9d253","timestamp":"2026-03-21T13:53:54.898Z","message":{"role":"toolResult","toolCallId":"call_49HJr13Sh0GQFgkNF0AgriTC","toolName":"read","content":[{"type":"text","text":"  disconnectSignal() {\n    this.signalClient.disconnect();\n    this.appendLog('已断开信令连接');\n  },\n\n  sendRawEnvelope(envelope) {\n    const sent = this.signalClient.sendEnvelope(envelope);\n    this.appendLog(sent ? `发送 ${envelope.type}` : `发送失败 ${envelope.type}`);\n  },\n\n  sendQuickHeartbeat() {\n    this.sendRawEnvelope(this.signalClient.sendHeartbeat());\n  },\n\n  sendQuickSync() {\n    this.sendRawEnvelope(this.signalClient.sendSync(cloneBoard(this.data.board), this.data.board.currentSide, this.data.board.moveHistory.length));\n  },\n\n  sendQuickAck() {\n    this.sendRawEnvelope(this.signalClient.sendAck(this.matchRoom.sequence));\n  },\n\n  sendQuickDrawOffer() {\n    this.sendRawEnvelope(this.signalClient.sendDrawOffer());\n  },\n\n  sendQuickDrawResponse() {\n    this.sendRawEnvelope(this.signalClient.sendDrawResponse(true));\n  },\n\n  sendQuickResign() {\n    this.sendRawEnvelope(this.signalClient.sendResign());\n  },\n\n  sendQuickError() {\n    this.sendRawEnvelope(this.signalClient.sendError('NETWORK_ERROR', 'demo error'));\n  },\n\n  simulateIncomingRequest() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.request',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 1,\n      ts: Date.now(),\n      payload: { desiredSide: Side.BLACK, seed: 7 },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 request');\n  },\n\n  simulateIncomingAccept() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.accept',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 2,\n      ts: Date.now(),\n      payload: { opponentId: 'remote-black', selfSide: Side.RED, seed: 7 },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 accept');\n  },\n\n  simulateIncomingMove() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.move',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 3,\n      ts: Date.now(),\n      payload: { move: { pieceId: 'r-r1', from: { x: 0, y: 9 }, to: { x: 0, y: 8 } } },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 move');\n  },\n\n  simulateIncomingSync() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.sync',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 4,\n      ts: Date.now(),\n      payload: { board: cloneBoard(this.data.board), turn: this.data.board.currentSide, moveSeq: this.data.board.moveHistory.length },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.setData({ syncMarkers: this.data.board.lastMove ? [this.data.board.lastMove.from, this.data.board.lastMove.to] : [] });\n    this.appendLog('模拟收到 sync');\n  },\n\n  simulateIncomingHeartbeat() {\n    this.signalClient.applyIncomingEnvelope({\n      v: '1.0',\n      type: 'match.heartbeat',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 5,\n      ts: Date.now(),\n      payload: { ping: Date.now() },\n    });\n    this.appendLog('模拟收到 heartbeat');\n  },\n\n  simulateIncomingDrawOffer() {\n    this.signalClient.applyIncomingEnvelope({\n      v: '1.0',\n      type: 'match.draw.offer',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 6,\n      ts: Date.now(),\n      payload: {},\n    });\n    this.appendLog('模拟收到 draw.offer');\n  },\n\n[172 more lines in file. Use offset=340 to continue.]"}],"isError":false,"timestamp":1774101234887}}
{"type":"message","id":"9f654876","parentId":"65b2a263","timestamp":"2026-03-21T13:54:45.758Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Fixing function mismatches**\n\nI need to address a mismatch in imported functions related to creating matches in game.js, especially with createMatchSignalClient and transport status. I’ll update the WXML to possibly include controls for the signal URL and connect/disconnect functions. There's also an issue with sendRawEnvelope incorrectly sending a boolean instead of the actual envelope. Also, I should ensure that signalClient methods return the envelope properly. Lastly, I need to check if connectSignal and disconnectSignal functions are linked to buttons that aren’t set up yet in the WXML and adjust accordingly.\n\n**Updating game.js and UI**\n\nI want to ensure the return of a boolean and possibly create a helper for debugging. I believe we need to patch game.js to allow sendQuick* to log these booleans and update the refresh on room changes to create syncMarkers, but I’m considering if that's necessary. The user asked to connect online matching to the WebSocket and signaling layer, which suggests implementing a client and possibly adding an input field for configuration. \n\nI also need to modify the UI in game.wxml to expose methods like connectSignal and incorporate a sample simulation card while keeping the existing online simulation panel. Finally, I need to set the transport and connection statuses based on changes.\n\n**Patching SocketTask and tests**\n\nI discovered that wx.connectSocket actually returns a SocketTask, which has methods like send and close. In a WeChat miniprogram, I should use task.send instead of wx.sendSocketMessage because our adapter seems buggy. I’ll need to patch the buildWxSocketAdapter accordingly and also make updates in match-signal.js. \n\nAdditionally, I found that the createMoveEvent and imported MatchEventType are not used, but that might be fine. I should check if there are any tests for these functions; if not, maybe we can add transport tests.\n\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_mUDVt1xNnkdajeq2QmKPCL83","name":"edit","arguments":{"file_path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/utils/match-signal.js","newText":"const {\n  MatchEventType,\n  createAckEvent,\n  createDrawOfferEvent,\n  createDrawResponseEvent,\n  createErrorEvent,\n  createHeartbeatEvent,\n  createMatchRoom,\n  createMoveEvent,\n  createResignEvent,\n  createSyncEvent,\n  isProtocolEnvelope,\n  applyMatchEvent,\n} = require('./match-protocol');\n\nconst TransportStatus = Object.freeze({\n  IDLE: 'idle',\n  CONNECTING: 'connecting',\n  OPEN: 'open',\n  CLOSING: 'closing',\n  CLOSED: 'closed',\n  ERROR: 'error',\n});\n\nfunction safeJsonParse(raw) {\n  if (raw && typeof raw === 'object') return raw;\n  if (typeof raw !== 'string') return null;\n  try {\n    return JSON.parse(raw);\n  } catch (error) {\n    return null;\n  }\n}\n\nfunction buildWxSocketAdapter(wxApi = typeof wx !== 'undefined' ? wx : null) {\n  if (!wxApi || typeof wxApi.connectSocket !== 'function') {\n    throw new Error('wx socket API is unavailable');\n  }\n\n  return {\n    open(url, handlers = {}) {\n      const task = wxApi.connectSocket({ url });\n      if (!task) throw new Error('failed to create socket task');\n\n      if (typeof task.onOpen === 'function') task.onOpen((event) => handlers.onOpen && handlers.onOpen(event));\n      if (typeof task.onClose === 'function') task.onClose((event) => handlers.onClose && handlers.onClose(event));\n      if (typeof task.onError === 'function') task.onError((event) => handlers.onError && handlers.onError(event));\n      if (typeof task.onMessage === 'function') task.onMessage((event) => handlers.onMessage && handlers.onMessage(event.data));\n\n      return {\n        send(data) {\n          if (typeof task.send === 'function') {\n            task.send({\n              data,\n              success: (res) => handlers.onSendSuccess && handlers.onSendSuccess(res),\n              fail: (err) => handlers.onSendError && handlers.onSendError(err),\n            });\n            return true;\n          }\n          if (typeof wxApi.sendSocketMessage === 'function') {\n            wxApi.sendSocketMessage({\n              data,\n              success: (res) => handlers.onSendSuccess && handlers.onSendSuccess(res),\n              fail: (err) => handlers.onSendError && handlers.onSendError(err),\n            });\n            return true;\n          }\n          return false;\n        },\n        close(code = 1000, reason = 'client close') {\n          if (typeof task.close === 'function') {\n            task.close({ code, reason });\n            return true;\n          }\n          if (typeof wxApi.closeSocket === 'function') {\n            wxApi.closeSocket({ code, reason });\n            return true;\n          }\n          return false;\n        },\n      };\n    },\n  };\n}\n\nfunction createMatchSignalClient({\n  room = createMatchRoom(),\n  url = '',\n  adapter = null,\n  onRoomChange = null,\n  onTransportChange = null,\n  onEnvelope = null,\n  onError = null,\n} = {}) {\n  const listeners = {\n    roomChange: onRoomChange,\n    transportChange: onTransportChange,\n    envelope: onEnvelope,\n    error: onError,\n  };\n\n  let transport = null;\n  let transportState = {\n    status: TransportStatus.IDLE,\n    url,\n    lastError: null,\n    connectedAt: null,\n    closedAt: null,\n    lastMessageAt: null,\n  };\n  let roomState = room;\n\n  const socketAdapter = adapter || (typeof wx !== 'undefined' ? buildWxSocketAdapter(wx) : null);\n\n  function emit(kind, payload, extra) {\n    const handler = listeners[kind];\n    if (typeof handler === 'function') handler(payload, extra);\n  }\n\n  function setTransportState(patch) {\n    transportState = { ...transportState, ...patch };\n    emit('transportChange', transportState, clientApi);\n  }\n\n  function setRoomState(nextRoom, envelope = null) {\n    roomState = nextRoom;\n    emit('roomChange', roomState, envelope, clientApi);\n  }\n\n  function handleEnvelope(envelope) {\n    if (!isProtocolEnvelope(envelope)) {\n      const error = { code: 'INVALID_ENVELOPE', message: 'not a valid protocol envelope', raw: envelope };\n      setTransportState({ status: TransportStatus.ERROR, lastError: error });\n      emit('error', error, clientApi);\n      return;\n    }\n\n    const nextRoom = applyMatchEvent(roomState, envelope);\n    setRoomState(nextRoom, envelope);\n    setTransportState({ lastMessageAt: envelope.ts || Date.now(), lastError: null });\n    emit('envelope', envelope, clientApi);\n  }\n\n  const clientApi = {\n    getTransportState: () => transportState,\n    getRoom: () => roomState,\n    setHandlers(nextHandlers = {}) {\n      Object.assign(listeners, nextHandlers);\n      return clientApi;\n    },\n    connect(nextUrl = transportState.url) {\n      if (!socketAdapter) {\n        const error = { code: 'ADAPTER_MISSING', message: 'socket adapter is unavailable' };\n        setTransportState({ status: TransportStatus.ERROR, lastError: error });\n        emit('error', error, clientApi);\n        return false;\n      }\n      if (!nextUrl) {\n        const error = { code: 'EMPTY_URL', message: 'signaling url is empty' };\n        setTransportState({ status: TransportStatus.ERROR, lastError: error });\n        emit('error', error, clientApi);\n        return false;\n      }\n\n      if (transport) {\n        clientApi.disconnect();\n      }\n\n      setTransportState({ status: TransportStatus.CONNECTING, url: nextUrl, lastError: null });\n      transport = socketAdapter.open(nextUrl, {\n        onOpen() {\n          setTransportState({ status: TransportStatus.OPEN, connectedAt: Date.now(), lastError: null });\n        },\n        onMessage(raw) {\n          const parsed = safeJsonParse(raw);\n          if (!parsed) {\n            const error = { code: 'PARSE_ERROR', message: 'message is not valid JSON', raw };\n            setTransportState({ status: TransportStatus.ERROR, lastError: error });\n            emit('error', error, clientApi);\n            return;\n          }\n          handleEnvelope(parsed);\n        },\n        onClose(event) {\n          setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now(), lastError: null, closeEvent: event || null });\n          transport = null;\n        },\n        onError(event) {\n          const error = { code: 'SOCKET_ERROR', message: 'socket error', event: event || null };\n          setTransportState({ status: TransportStatus.ERROR, lastError: error });\n          emit('error', error, clientApi);\n        },\n        onSendError(err) {\n          const error = { code: 'SEND_ERROR', message: 'failed to send socket message', event: err || null };\n          setTransportState({ status: TransportStatus.ERROR, lastError: error });\n          emit('error', error, clientApi);\n        },\n      });\n\n      return true;\n    },\n    disconnect() {\n      if (!transport) {\n        setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now() });\n        return true;\n      }\n      setTransportState({ status: TransportStatus.CLOSING });\n      try {\n        transport.close();\n      } finally {\n        transport = null;\n        setTransportState({ status: TransportStatus.CLOSED, closedAt: Date.now() });\n      }\n      return true;\n    },\n    sendEnvelope(envelope) {\n      if (!transport || transportState.status !== TransportStatus.OPEN) return false;\n      const payload = JSON.stringify(envelope);\n      return transport.send(payload);\n    },\n    sendMove(move, meta = {}) {\n      return clientApi.sendEnvelope(createMoveEvent({ roomId: roomState.roomId, senderId: roomState.selfId, move, seq: meta.seq || roomState.sequence }));\n    },\n    sendAck(ackSeq, hash = null) {\n      return clientApi.sendEnvelope(createAckEvent({ roomId: roomState.roomId, senderId: roomState.selfId, ackSeq, hash }));\n    },\n    sendSync(board, turn, moveSeq = 0) {\n      return clientApi.sendEnvelope(createSyncEvent({ roomId: roomState.roomId, senderId: roomState.selfId, board, turn, moveSeq }));\n    },\n    sendHeartbeat(ping = Date.now()) {\n      return clientApi.sendEnvelope(createHeartbeatEvent({ roomId: roomState.roomId, senderId: roomState.selfId, ping }));\n    },\n    sendDrawOffer() {\n      return clientApi.sendEnvelope(createDrawOfferEvent({ roomId: roomState.roomId, senderId: roomState.selfId }));\n    },\n    sendDrawResponse(accepted = false) {\n      return clientApi.sendEnvelope(createDrawResponseEvent({ roomId: roomState.roomId, senderId: roomState.selfId, accepted }));\n    },\n    sendResign() {\n      return clientApi.sendEnvelope(createResignEvent({ roomId: roomState.roomId, senderId: roomState.selfId }));\n    },\n    sendError(code, message) {\n      return clientApi.sendEnvelope(createErrorEvent({ roomId: roomState.roomId, senderId: roomState.selfId, code, message }));\n    },\n    ingest(raw) {\n      const parsed = safeJsonParse(raw);\n      if (!parsed) return false;\n      handleEnvelope(parsed);\n      return true;\n    },\n    applyIncomingEnvelope(envelope) {\n      handleEnvelope(envelope);\n      return roomState;\n    },\n    dispose() {\n      clientApi.disconnect();\n    },\n  };\n\n  return clientApi;\n}\n\nmodule.exports = {\n  TransportStatus,\n  safeJsonParse,\n  buildWxSocketAdapter,\n  createMatchSignalClient,\n};\n","new_string":"const {\n  MatchEventType,\n  createAckEvent,\n  createDrawOfferEvent,\n  createDrawResponseEvent,\n  createErrorEvent,\n  createHeartbeatEvent,\n  createMatchRoom,\n  createMoveEvent,\n  createResignEvent,\n  createSyncEvent,\n  isProtocolEnvelope,\n  applyMatchEvent,\n} = require('./match-protocol');\n\nconst TransportStatus = Object.freeze({\n  IDLE: 'idle',\n  CONNECTING: 'connecting',\n  OPEN: 'open',\n  CLOSING: 'closing',\n  CLOSED