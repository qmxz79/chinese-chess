{"type":"message","id":"09b44b0c","parentId":"d53a037d","timestamp":"2026-03-21T13:53:25.828Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_NqVdDhhPYLdass1UVMEYpxTV","name":"write","arguments":{"content":"const { createGameState } = require('../../utils/game-state');\nconst {\n  Side,\n  createInitialBoard,\n  cloneBoard,\n  getPieceAt,\n  getLegalMoves,\n  advanceGame,\n  searchBestMove,\n  pieceLabel,\n} = require('../../utils/chess-engine');\nconst {\n  MatchMode,\n  MatchState,\n  createMatchRoom,\n} = require('../../utils/match-protocol');\nconst {\n  TransportStatus,\n  createMatchSignalClient,\n} = require('../../utils/match-signal');\nconst { saveLastMatch, saveMatchRoom, loadMatchRoom } = require('../../utils/match-store');\n\nfunction coordKey(x, y) {\n  return `${x}:${y}`;\n}\n\nfunction formatCoord({ x, y }) {\n  return `(${x},${y})`;\n}\n\nfunction buildBoardView(board, selectedPieceId, legalMoves, hintMove, syncMarkers) {\n  const legalMap = new Set((legalMoves || []).map((move) => coordKey(move.to.x, move.to.y)));\n  const hintMap = hintMove\n    ? new Set([coordKey(hintMove.from.x, hintMove.from.y), coordKey(hintMove.to.x, hintMove.to.y)])\n    : new Set();\n  const syncMap = new Set((syncMarkers || []).map((move) => coordKey(move.x, move.y)));\n  const lastMoveMap = board.lastMove\n    ? new Set([coordKey(board.lastMove.from.x, board.lastMove.from.y), coordKey(board.lastMove.to.x, board.lastMove.to.y)])\n    : new Set();\n\n  const rows = [];\n  for (let y = 0; y < 10; y += 1) {\n    const cells = [];\n    for (let x = 0; x < 9; x += 1) {\n      const piece = getPieceAt(board, x, y);\n      const selected = piece && piece.id === selectedPieceId;\n      const legalTarget = legalMap.has(coordKey(x, y));\n      const hintTarget = hintMap.has(coordKey(x, y));\n      const syncTarget = syncMap.has(coordKey(x, y));\n      const lastMove = lastMoveMap.has(coordKey(x, y));\n      cells.push({\n        x,\n        y,\n        key: coordKey(x, y),\n        piece,\n        text: piece ? pieceLabel(piece) : '',\n        selected,\n        legalTarget,\n        hintTarget,\n        syncTarget,\n        lastMove,\n      });\n    }\n    rows.push({ y, cells });\n  }\n  return rows;\n}\n\nPage({\n  data: {\n    state: createGameState(),\n    board: createInitialBoard(),\n    boardRows: [],\n    selectedPieceId: null,\n    legalMoves: [],\n    hintMove: null,\n    hintText: '点击“提示”获取推荐走法',\n    matchRoom: createMatchRoom(),\n    connectionStatus: '未连接在线房间',\n    transportStatus: TransportStatus.IDLE,\n    signalUrl: '',\n    syncMarkers: [],\n    logLines: [],\n    tips: [\n      '点棋子选中，再点可落位置',\n      '红方先手，目前默认人机对战',\n      '提示会推荐当前回合的一步走法',\n      '在线匹配协议层已接入本地模拟房间'\n    ],\n  },\n\n  onLoad() {\n    this.boardHistory = [];\n    this.aiTimer = null;\n    const storedRoom = loadMatchRoom();\n    this.matchRoom = storedRoom || createMatchRoom({ mode: MatchMode.ONLINE, state: MatchState.IDLE });\n    this.signalClient = createMatchSignalClient({\n      room: this.matchRoom,\n      url: '',\n      onRoomChange: (room) => this.onRoomChange(room),\n      onTransportChange: (transport) => this.onTransportChange(transport),\n      onEnvelope: (envelope) => this.appendLog(`收到 ${envelope.type}`),\n      onError: (error) => this.appendLog(`错误：${error.code}`),\n    });\n    this.setData({ matchRoom: this.matchRoom, connectionStatus: this.describeConnection(this.matchRoom) });\n    this.refreshBoard('游戏页已就绪');\n  },\n\n  onUnload() {\n    if (this.aiTimer) clearTimeout(this.aiTimer);\n    if (this.signalClient) this.signalClient.dispose();\n  },\n\n  appendLog(line) {\n    const next = [line, ...this.data.logLines].slice(0, 8);\n    this.setData({ logLines: next });\n  },\n\n  onRoomChange(room) {\n    this.matchRoom = room;\n    this.setData({ matchRoom: room });\n    saveMatchRoom(room);\n    this.refreshBoard(`在线房间：${room.state}`);\n  },\n\n  onTransportChange(transport) {\n    this.setData({ transportStatus: transport.status, connectionStatus: this.describeTransport(transport) });\n  },\n\n  describeTransport(transport) {\n    if (!transport) return '未连接在线房间';\n    return `${transport.status}${transport.url ? ` · ${transport.url}` : ''}`;\n  },\n\n  describeConnection(room) {\n    if (!room) return '未连接在线房间';\n    if (room.state === MatchState.PLAYING) return `在线房间 ${room.roomId || '待分配'} · 可走子`;\n    if (room.state === MatchState.MATCHING) return `在线房间 ${room.roomId || '待分配'} · 匹配中`;\n    if (room.state === MatchState.SYNCHRONIZING) return `在线房间 ${room.roomId || '待分配'} · 同步中`;\n    if (room.state === MatchState.FINISHED) return `在线房间 ${room.roomId || '待分配'} · 已结束`;\n    if (room.state === MatchState.ERROR) return `在线房间 ${room.roomId || '待分配'} · 异常`;\n    return `在线房间 ${room.roomId || '待分配'} · 待开始`;\n  },\n\n  refreshBoard(message, overrideLegalMoves, overrideHintMove, overrideSyncMarkers) {\n    const legalMoves = getLegalMoves(this.data.board, this.data.board.currentSide);\n    const boardRows = buildBoardView(\n      this.data.board,\n      this.data.selectedPieceId,\n      overrideLegalMoves || this.data.legalMoves,\n      overrideHintMove === undefined ? this.data.hintMove : overrideHintMove,\n      overrideSyncMarkers === undefined ? this.data.syncMarkers : overrideSyncMarkers,\n    );\n    const summary = this.getStatusText(this.data.board, message);\n    this.setData({\n      state: {\n        ...this.data.state,\n        status: this.data.board.status,\n        winner: this.data.board.winner,\n        side: this.data.board.currentSide,\n        moveCount: this.data.board.moveHistory.length,\n        message: summary,\n      },\n      boardRows,\n      legalMoves,\n      boardLabel: summary,\n    });\n  },\n\n  getStatusText(board, fallback) {\n    if (board.status === 'checkmate') {\n      return board.winner === Side.RED ? '红方胜，已将死' : '黑方胜，已将死';\n    }\n    if (board.status === 'draw') return '平局';\n    if (board.status === 'check') return `${board.currentSide === Side.RED ? '红方' : '黑方'}被将军`;\n    return fallback || `${board.currentSide === Side.RED ? '红方' : '黑方'}走子`;\n  },\n\n  saveMatchResult(finalBoard) {\n    const winnerText = finalBoard.status === 'draw'\n      ? '平局'\n      : finalBoard.winner === Side.RED\n        ? '红方胜'\n        : '黑方胜';\n    const replayMoves = finalBoard.moveHistory.map((move) => ({\n      pieceId: move.pieceId,\n      from: move.from,\n      to: move.to,\n      capturedPieceId: move.capturedPieceId,\n    }));\n\n    saveLastMatch({\n      finishedAt: Date.now(),\n      status: finalBoard.status,\n      winner: finalBoard.winner,\n      winnerText,\n      moveCount: finalBoard.moveHistory.length,\n      summary: this.getStatusText(finalBoard),\n      moves: replayMoves,\n      finalBoard: cloneBoard(finalBoard),\n    });\n  },\n\n  persistMatchRoom(room) {\n    this.matchRoom = room;\n    this.setData({ matchRoom: room, connectionStatus: this.describeConnection(room) });\n    saveMatchRoom(room);\n  },\n\n  connectSignal() {\n    const url = this.data.signalUrl.trim();\n    if (!url) {\n      this.appendLog('请先填写信令地址');\n      return;\n    }\n    const ok = this.signalClient.connect(url);\n    if (ok) this.appendLog(`连接中：${url}`);\n  },\n\n  disconnectSignal() {\n    this.signalClient.disconnect();\n    this.appendLog('已断开信令连接');\n  },\n\n  sendRawEnvelope(envelope) {\n    const sent = this.signalClient.sendEnvelope(envelope);\n    this.appendLog(sent ? `发送 ${envelope.type}` : `发送失败 ${envelope.type}`);\n  },\n\n  sendQuickHeartbeat() {\n    this.sendRawEnvelope(this.signalClient.sendHeartbeat());\n  },\n\n  sendQuickSync() {\n    this.sendRawEnvelope(this.signalClient.sendSync(cloneBoard(this.data.board), this.data.board.currentSide, this.data.board.moveHistory.length));\n  },\n\n  sendQuickAck() {\n    this.sendRawEnvelope(this.signalClient.sendAck(this.matchRoom.sequence));\n  },\n\n  sendQuickDrawOffer() {\n    this.sendRawEnvelope(this.signalClient.sendDrawOffer());\n  },\n\n  sendQuickDrawResponse() {\n    this.sendRawEnvelope(this.signalClient.sendDrawResponse(true));\n  },\n\n  sendQuickResign() {\n    this.sendRawEnvelope(this.signalClient.sendResign());\n  },\n\n  sendQuickError() {\n    this.sendRawEnvelope(this.signalClient.sendError('NETWORK_ERROR', 'demo error'));\n  },\n\n  simulateIncomingRequest() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.request',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 1,\n      ts: Date.now(),\n      payload: { desiredSide: Side.BLACK, seed: 7 },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 request');\n  },\n\n  simulateIncomingAccept() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.accept',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 2,\n      ts: Date.now(),\n      payload: { opponentId: 'remote-black', selfSide: Side.RED, seed: 7 },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 accept');\n  },\n\n  simulateIncomingMove() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.move',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 3,\n      ts: Date.now(),\n      payload: { move: { pieceId: 'r-r1', from: { x: 0, y: 9 }, to: { x: 0, y: 8 } } },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.appendLog('模拟收到 move');\n  },\n\n  simulateIncomingSync() {\n    const envelope = {\n      v: '1.0',\n      type: 'match.sync',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 4,\n      ts: Date.now(),\n      payload: { board: cloneBoard(this.data.board), turn: this.data.board.currentSide, moveSeq: this.data.board.moveHistory.length },\n    };\n    this.signalClient.applyIncomingEnvelope(envelope);\n    this.setData({ syncMarkers: this.data.board.lastMove ? [this.data.board.lastMove.from, this.data.board.lastMove.to] : [] });\n    this.appendLog('模拟收到 sync');\n  },\n\n  simulateIncomingHeartbeat() {\n    this.signalClient.applyIncomingEnvelope({\n      v: '1.0',\n      type: 'match.heartbeat',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 5,\n      ts: Date.now(),\n      payload: { ping: Date.now() },\n    });\n    this.appendLog('模拟收到 heartbeat');\n  },\n\n  simulateIncomingDrawOffer() {\n    this.signalClient.applyIncomingEnvelope({\n      v: '1.0',\n      type: 'match.draw.offer',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 6,\n      ts: Date.now(),\n      payload: {},\n    });\n    this.appendLog('模拟收到 draw.offer');\n  },\n\n  simulateIncomingError() {\n    this.signalClient.applyIncomingEnvelope({\n      v: '1.0',\n      type: 'match.error',\n      roomId: this.matchRoom.roomId || 'room-demo-001',\n      senderId: 'remote-black',\n      seq: 7,\n      ts: Date.now(),\n      payload: { code: 'NETWORK_ERROR', message: 'mock offline' },\n    });\n    this.appendLog('模拟收到 error');\n  },\n\n  resetMatchRoom() {\n    const room = createMatchRoom({ roomId: 'room-demo-001', selfId: 'local-red', selfSide: Side.RED, mode: MatchMode.ONLINE, state: MatchState.IDLE });\n    this.persistMatchRoom(room);\n    this.setData({ syncMarkers: [] });\n    this.appendLog('在线房间已重置');\n    this.refreshBoard('在线房间已重置');\n  },\n\n  resetGame() {\n    if (this.aiTimer) clearTimeout(this.aiTimer);\n    this.boardHistory = [];\n    this.setData({\n      board: createInitialBoard(),\n      selectedPieceId: null,\n      legalMoves: [],\n      hintMove: null,\n      hintText: '点击“提示”获取推荐走法',\n      syncMarkers: [],\n    });\n    this.refreshBoard('对局已重开');\n  },\n\n  undoMove() {\n    if (!this.boardHistory || !this.boardHistory.length) return;\n    if (this.aiTimer) clearTimeout(this.aiTimer);\n\n    const stepsToUndo = this.data.state.mode === 'ai' && this.data.board.currentSide === Side.RED ? 2 : 1;\n    let previous = null;\n    for (let i = 0; i < stepsToUndo; i += 1) {\n      if (!this.boardHistory.length) break;\n      previous = this.boardHistory.pop();\n    }\n    if (!previous) return;\n\n    this.setData({\n      board: cloneBoard(previous),\n      selectedPieceId: null,\n      legalMoves: [],\n      hintMove: null,\n      hintText: stepsToUndo === 2 ? '已悔棋两步，轮到你重新落子' : '已悔棋一步',\n    });\n    this.refreshBoard(stepsToUndo === 2 ? '已悔棋两步' : '已悔棋一步');\n  },\n\n  showHint() {\n    if (this.data.board.status === 'checkmate' || this.data.board.status === 'draw') {\n      this.setData({ hintMove: null, hintText: '对局已结束，无法提示' });\n      this.refreshBoard('对局已结束');\n      return;\n    }\n    if (this.data.board.currentSide !== Side.RED) {\n      this.setData({ hintMove: null, hintText: '当前轮到黑方，先等 AI 走完' });\n      this.refreshBoard('当前轮到黑方');\n      return;\n    }\n\n    const hintMove = searchBestMove(this.data.board, { side: Side.RED, depth: 2, timeLimitMs: 60 });\n    if (!hintMove) {\n      this.setData({ hintMove: null, hintText: '当前没有可用提示' });\n      this.refreshBoard('当前没有可用提示');\n      return;\n    }\n\n    const piece = getPieceAt(this.data.board, hintMove.from.x, hintMove.from.y);\n    const hintText = `${piece ? pieceLabel(piece) : '棋子'} 建议走 ${formatCoord(hintMove.from)} → ${formatCoord(hintMove.to)}`;\n    this.setData({\n      hintMove,\n      hintText,\n      selectedPieceId: piece ? piece.id : null,\n      legalMoves: getLegalMoves(this.data.board, Side.RED).filter((move) => move.pieceId === hintMove.pieceId),\n    });\n    this.refreshBoard('已给出提示', this.data.legalMoves, hintMove);\n  },\n\n  onCellTap(e) {\n    if (this.data.board.status === 'checkmate' || this.data.board.status === 'draw') return;\n    if (this.data.board.currentSide === Side.BLACK) return;\n\n    const x = Number(e.currentTarget.dataset.x);\n    const y = Number(e.currentTarget.dataset.y);\n    const piece = getPieceAt(this.data.board, x, y);\n    const selectedPieceId = this.data.selectedPieceId;\n    const selectedMoves = this.data.legalMoves;\n    const legalMove = selectedMoves.find((move) => move.to.x === x && move.to.y === y);\n\n    if (legalMove) {\n      this.commitMove(legalMove, '你走了一步');\n      return;\n    }\n\n    if (piece && piece.side === Side.RED && this.data.board.currentSide === Side.RED) {\n      const moves = getLegalMoves(this.data.board, Side.RED).filter((move) => move.pieceId === piece.id);\n      this.setData({\n        selectedPieceId: piece.id,\n        legalMoves: moves,\n        hintMove: null,\n        hintText: `已选中 ${pieceLabel(piece)}，可落点已高亮`,\n      });\n      this.refreshBoard(`${pieceLabel(piece)}已选中`, moves, null);\n      return;\n    }\n\n    if (selectedPieceId) {\n      this.setData({ selectedPieceId: null, legalMoves: [], hintMove: null, hintText: '已取消选中' });\n      this.refreshBoard('取消选中', [], null);\n    }\n  },\n\n  finishIfNeeded(nextBoard) {\n    if (nextBoard.status === 'playing') return false;\n    this.saveMatchResult(nextBoard);\n    const resultUrl = `/pages/result/result?status=${nextBoard.status}&winner=${nextBoard.winner || ''}`;\n    wx.reLaunch({ url: resultUrl });\n    return true;\n  },\n\n  commitMove(move, message) {\n    this.boardHistory.push(cloneBoard(this.data.board));\n    const nextBoard = advanceGame(this.data.board, move);\n    this.setData({\n      board: nextBoard,\n      selectedPieceId: null,\n      legalMoves: [],\n      hintMove: null,\n      hintText: message,\n    });\n    this.refreshBoard(message, [], null);\n\n    if (this.finishIfNeeded(nextBoard)) return;\n\n    if (nextBoard.status === 'playing' && nextBoard.currentSide === Side.BLACK) {\n      this.scheduleAiMove();\n    }\n  },\n\n  scheduleAiMove() {\n    if (this.aiTimer) clearTimeout(this.aiTimer);\n    this.aiTimer = setTimeout(() => {\n      this.aiTimer = null;\n      const move = searchBestMove(this.data.board, { side: Side.BLACK, depth: 1, timeLimitMs: 80 });\n      if (!move) {\n        this.setData({ hintMove: null, hintText: 'AI 无合法走法' });\n        this.refreshBoard('AI 无合法走法');\n        return;\n      }\n      this.commitMove(move, 'AI 已落子');\n    }, 180);\n  },\n\n  startGame() {\n    this.resetGame();\n  },\n\n  goResult() {\n    wx.navigateTo({ url: '/pages/result/result' });\n  },\n});\n","file_path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.js","path":"/home/gem/workspace/agent/workspace/chinese-chess-minigame/miniprogram/pages/game/game.js"}}],"api":"openai-completions","provider":"code889","model":"gpt-5.4-mini","usage":{"input":2972,"output":5072,"cacheRead":80896,"cacheWrite":0,"totalTokens":88940,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774101165357}}
