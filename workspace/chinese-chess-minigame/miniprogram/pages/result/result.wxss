.section-title { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx; }
.summary { margin-bottom: 8rpx; }
.meta { color: #666; margin-bottom: 16rpx; }
.actions { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 16rpx; }
.board-shell {
  padding: 18rpx;
  background: #ead9b4;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}
.board-grid {
  background: #f8e8c4;
  border: 2rpx solid #a07b46;
  border-radius: 16rpx;
  overflow: hidden;
}
.board-row { display: flex; }
.board-cell {
  width: 52rpx;
  height: 52rpx;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(160, 123, 70, 0.25);
  border-bottom: 1rpx solid rgba(160, 123, 70, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}
.board-row:last-child .board-cell { border-bottom: none; }
.board-cell:last-child { border-right: none; }
.piece {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}
.piece-red {
  background: #f8efe2;
  color: #b8362d;
  border: 2rpx solid #c06b63;
}
.piece-black {
  background: #f6f1e8;
  color: #333;
  border: 2rpx solid #666;
}
