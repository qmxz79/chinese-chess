.page {
  padding: 24rpx;
}
.card {
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}
.title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.subtitle {
  color: #666;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.summary, .meta {
  color: #666;
  margin-bottom: 16rpx;
}
.board-shell {
  padding: 18rpx;
  background: #ead9b4;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}
.board-grid {
  background: #f8e8c4;
  border: 2rpx solid #a07b46;
  border-radius: 16rpx;
  overflow: hidden;
}
.board-row { display: flex; }
.board-cell {
  width: 76rpx;
  height: 76rpx;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(160, 123, 70, 0.35);
  border-bottom: 1rpx solid rgba(160, 123, 70, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.board-row:last-child .board-cell { border-bottom: none; }
.board-cell:last-child { border-right: none; }
.piece {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.12);
}
.piece-red {
  background: #f8efe2;
  color: #b8362d;
  border: 2rpx solid #c06b63;
}
.piece-black {
  background: #f6f1e8;
  color: #333;
  border: 2rpx solid #666;
}
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
button { margin-top: 16rpx; }
